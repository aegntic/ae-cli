    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {},
  "devDependencies": {
    "@aegntic/sdk": "workspace:*",
    "citty": "^0.1.6",
    "consola": "^3.4.0",
    "pathe": "^2.0.0",
    "esbuild": "^0.24.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
