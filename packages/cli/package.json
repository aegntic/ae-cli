{
  "name": "@aegntic/aedex",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "aedex": "dist/index.js",
    "ae": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": ["dist"],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --log-level=warning && chmod +x dist/index.js",
