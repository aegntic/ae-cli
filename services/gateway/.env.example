# Gateway local-dev config. Real values live in services/gateway/.env (gitignored).
# Prod secrets go to `fly secrets set`, never in this repo.

PORT=3101
# Local dev: dockerized postgres on :5435 (aegntic-pg-p2, the unified signed-ledger
# schema). :5434 holds a stale legacy schema — do not use.
DATABASE_URL=postgresql://aedex:aedex@localhost:5435/aedex

# Allowed web origin for CORS. Prod = the Vercel web URL.
CORS_ORIGIN=http://localhost:3000

# Persistent Ed25519 seed for sealing the balance_ledger chain. If unset, the
# gateway generates an ephemeral key on boot and logs a loud warning — ledger
# entries signed under an ephemeral key become unverifiable across restarts.
# NEVER ship to prod without this set. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# AEGNTIC_LEDGER_SIGNING_SEED=

# Stripe billing. The webhook handler verifies the Stripe-Signature header with
# STRIPE_WEBHOOK_SECRET — without it the webhook is rejected.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Apify provider token. Rotate pre-launch as hygiene.
# AEGNTIC_APIFY_TOKEN=
