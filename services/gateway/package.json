{
  "name": "@aegntic/gateway",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "aegntic-mcp": "dist/mcp/server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "mcp": "tsx src/mcp/server.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push --force",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed-catalog": "tsx src/db/seed-catalog.ts"
  },
  "dependencies": {
    "@aegntic/sdk": "workspace:*",
    "@hono/node-server": "^1.14.0",
    "@noble/ed25519": "^2",
    "@noble/hashes": "^1",
    "argon2": "^0.41.0",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.7.0",
    "nanoid": "^5.0.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
