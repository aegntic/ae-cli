    </footer>

    <script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
        // Loader
        window.addEventListener('load',()=>{
            setTimeout(()=>{
                document.getElementById('loader').classList.add('done');
            },600);
        });

        // Logo hide on scroll to avoid watermark overlap
        const navLogo=document.querySelector('.nav-logo');
        let logoHidden=false;
        window.addEventListener('scroll',()=>{
            const threshold=window.innerHeight*0.15;
            const shouldHide=window.scrollY>threshold;
            if(shouldHide&&!logoHidden){navLogo.classList.add('hidden');logoHidden=true}
            else if(!shouldHide&&logoHidden){navLogo.classList.remove('hidden');logoHidden=false}
        },{passive:true});

        // Menu toggle
        function toggleMenu(){
            const btn=document.getElementById('menuBtn');
            const menu=document.getElementById('site-menu');
            const isOpen=menu.classList.contains('open');
            if(isOpen){
                closeMenu();
            }else{
                menu.classList.add('open');
                menu.setAttribute('aria-hidden','false');
                btn.classList.add('open');
                btn.setAttribute('aria-expanded','true');
            }
        }
        function closeMenu(){
            const btn=document.getElementById('menuBtn');
            const menu=document.getElementById('site-menu');
            menu.classList.remove('open');
            menu.setAttribute('aria-hidden','true');
            btn.classList.remove('open');
            btn.setAttribute('aria-expanded','false');
        }
        // Close menu on outside click
        document.addEventListener('click',e=>{
            const btn=document.getElementById('menuBtn');
            const menu=document.getElementById('site-menu');
            if(menu.classList.contains('open') && !btn.contains(e.target) && !menu.contains(e.target)){
                closeMenu();
            }
        });

        // Smooth scroll for nav links
        document.querySelectorAll('a[href^="#"]').forEach(a=>{
            a.addEventListener('click',e=>{
                const target=document.querySelector(a.getAttribute('href'));
                if(target){e.preventDefault();target.scrollIntoView({behavior:'smooth'})}
            });
        });

        // ── SCROLL PROGRESS BAR ──
        const progressBar=document.getElementById('scrollProgress');
        const floatingCta=document.getElementById('floatingCta');
        let ctaVisible=false;
        function updateProgress(){
            const st=window.scrollY;
            const dh=document.documentElement.scrollHeight-window.innerHeight;
            const pct=dh>0?(st/dh)*100:0;
            progressBar.style.width=pct+'%';
            // Show floating CTA after scrolling past 40% of viewport
            const shouldShow=st>window.innerHeight*0.4;
            if(shouldShow&&!ctaVisible){floatingCta.classList.add('visible');ctaVisible=true}
            else if(!shouldShow&&ctaVisible){floatingCta.classList.remove('visible');ctaVisible=false}
        }
        window.addEventListener('scroll',updateProgress,{passive:true});
        updateProgress();

        // ── HERO SCROLL INDICATOR → scroll to manifesto ──
        document.querySelector('.hero-scroll')?.addEventListener('click',()=>{
            document.querySelector('#manifesto')?.scrollIntoView({behavior:'smooth'});
        });

        // ── MAGNETIC SERVICE TAGS (cursor-following micro-interaction) ──
        const magneticTags=document.querySelectorAll('.service-tag');
        const isDesktop=window.matchMedia('(min-width:1024px) and (hover:hover)').matches;
        if(isDesktop&&!window.matchMedia('(prefers-reduced-motion: reduce)').matches){
            magneticTags.forEach(tag=>{
                tag.addEventListener('mousemove',e=>{
                    const r=tag.getBoundingClientRect();
                    const x=e.clientX-r.left-r.width/2;
                    const y=e.clientY-r.top-r.height/2;
                    tag.style.transform=`translate(${x*0.3}px,${y*0.3}px)`;
                    tag.classList.add('magnetic-active');
                });
                tag.addEventListener('mouseleave',()=>{
                    tag.style.transform='';
                    tag.classList.remove('magnetic-active');
                });
            });
        }

        // Service cards scroll reveal (SOHub overlapping pattern)
        if(window.matchMedia('(min-width:1024px)').matches){
            const cards=document.querySelectorAll('.service-card');
            cards.forEach((card,i)=>{
                card.style.clipPath='inset(0 0 0 0)';
                card.style.transition='none';
            });
            const stack=document.querySelector('.services-stack');
            if(stack){
                const totalCards=cards.length;
                const cardPeek=5; // rem between cards
                const cardH=cards[0].offsetHeight;
                const scrollPerCard=cardH; // scroll one full card height per card
                const totalScroll=scrollPerCard*(totalCards-1);
                stack.style.height=totalScroll+cardH+'px';

                cards.forEach((card,i)=>{
                    card.style.position='sticky';
                    card.style.top=(i*cardPeek)+'rem';
                    card.style.left='0';
                    card.style.right='0';
                });
            }
        }

        // ── GSAP TEXT EFFECTS ──
        (function(){
            if(!window.gsap||!window.ScrollTrigger){return}
            gsap.registerPlugin(ScrollTrigger);
            const reduce=window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            document.body.classList.add('gsap-ready');

            // Cancel hero CSS fade so GSAP controls it
            if(reduce){
                document.querySelectorAll('[data-split] .split-inner,[data-split]').forEach(()=>{});
                // Force-show everything
                gsap.set('[data-split] .split-inner',{clearProps:'all'});
                gsap.set('.reveal-fade,.reveal-clip',{clearProps:'all'});
                gsap.set('.work-item-bg img',{clearProps:'transform'});
                gsap.set('.intro-eyebrow::before',{clearProps:'all'}); // noop, pseudo handled by CSS
                return;
            }

            // Word splitter — preserves <em>/<strong> as opaque word units, keeps <br>
            function splitWords(el){
                const nodes=Array.from(el.childNodes);
                el.innerHTML='';
                nodes.forEach(n=>{
                    if(n.nodeType===3){
                        const parts=n.textContent.split(/(\s+)/);
                        parts.forEach(p=>{
                            if(p===''){return}
                            if(/^\s+$/.test(p)){el.appendChild(document.createTextNode(' '));return}
                            const mask=document.createElement('span');mask.className='split-mask';
                            const inner=document.createElement('span');inner.className='split-inner';inner.textContent=p;
                            mask.appendChild(inner);el.appendChild(mask);
                        });
                    } else if(n.nodeType===1){
                        const tag=n.tagName.toLowerCase();
                        if(tag==='br'){el.appendChild(n);return}
                        const mask=document.createElement('span');mask.className='split-mask';
                        n.classList.add('split-inner');
                        mask.appendChild(n);el.appendChild(mask);
                    }
                });
            }

            // Run split on every [data-split]
            document.querySelectorAll('[data-split]').forEach(splitWords);

            const ease='expo.out';
            const easeSoft='power3.out';
            const easeClip='power4.inOut';

            // ── HERO timeline (runs after loader) ──
            const heroTL=gsap.timeline({delay:0.5});
            heroTL.fromTo('.hero-headline .split-inner',
                {yPercent:120},
                {yPercent:0,duration:1.6,ease:ease,stagger:0.1}
            );

            // ── Scroll-triggered word reveals ──
            gsap.utils.toArray('.intro-hook, .intro-lead, .section-heading, .intro-tagline, .cta-display').forEach(el=>{
                const inners=el.querySelectorAll('.split-inner');
                if(!inners.length){return}
                gsap.fromTo(inners,
                    {yPercent:120},
                    {yPercent:0,duration:1.4,ease:ease,stagger:0.08,
                    scrollTrigger:{trigger:el,start:'top 82%',toggleActions:'play none none reverse'}}
                );
            });

            // ── Intro eyebrow line draw + fade ──
            gsap.to('.intro-eyebrow::before',{}); // pseudo handled via CSS class toggle
            document.querySelectorAll('.intro-eyebrow').forEach(el=>{
                gsap.fromTo(el,{opacity:0,x:-16},{
                    opacity:1,x:0,duration:1.0,ease:easeSoft,
                    scrollTrigger:{trigger:el,start:'top 85%',toggleActions:'play none none reverse'}
                });
            });
            // Pseudo line draw — animate via CSS class
            document.querySelectorAll('.intro-eyebrow').forEach(el=>{
                ScrollTrigger.create({
                    trigger:el,start:'top 85%',
                    onEnter:()=>el.classList.add('line-drawn'),
                    onLeaveBack:()=>el.classList.remove('line-drawn')
                });
            });

            // ── Intro figure: static dominant bg-style (no entrance / no float) ──
            // (Per design directive: image is a static visual anchor, not an animated element.)
            // gsap.utils.toArray('.intro-figure').forEach(el=>{
            //     gsap.fromTo(el,
            //         {xPercent:-40,scale:0.9,opacity:0},
            //         {xPercent:-22,scale:1,opacity:1,duration:1.6,ease:easeSoft,
            //         scrollTrigger:{trigger:'.intro',start:'top 60%',toggleActions:'play none none reverse'}}
            //     );
            // });

            // ── Prose / desc / sub fade-up ──
            gsap.utils.toArray('.intro-prose p, .section-desc, .cta-sub, .ae-promo-sub, .ae-promo-desc').forEach(el=>{
                gsap.fromTo(el,{y:48,opacity:0},{
                    y:0,opacity:1,duration:1.3,ease:easeSoft,
                    scrollTrigger:{trigger:el,start:'top 85%',toggleActions:'play none none reverse'}
                });
            });

            // ── Work card directional clip reveal ──
            const clips=[
                'inset(0 100% 0 0)',
                'inset(0 0 100% 0)',
                'inset(0 0 0 100%)',
                'inset(100% 0 0 0)'
            ];
            ScrollTrigger.create({
                trigger:'.work-grid',start:'top 78%',
                onEnter:()=>{
                    document.querySelectorAll('.work-item').forEach((card,i)=>{
                        gsap.fromTo(card,{
                            clipPath:clips[i%clips.length],opacity:1
                        },{
                            clipPath:'inset(0 0 0 0)',duration:1.5,ease:easeClip,delay:i*0.14
                        });
                    });
                    document.querySelectorAll('.work-item-bg img').forEach((img,i)=>{
                        gsap.to(img,{
                            scale:1,duration:1.8,ease:'power3.out',delay:i*0.14
                        });
                    });
                },
                onLeaveBack:()=>{
                    // reset so re-entry plays again
                    document.querySelectorAll('.work-item').forEach((card,i)=>{
                        gsap.set(card,{clipPath:clips[i%clips.length]});
                    });
                    document.querySelectorAll('.work-item-bg img').forEach(img=>{
                        gsap.set(img,{scale:1.15});
                    });
                }
            });

            // ── Service cards: scrubbed stacking reveal with clip-path transitions ──
            // Each card uses clip-path to reveal/hide body content as user scrolls.
            // Headings always peek through; next card body reaches full opacity by tagline.
            document.querySelectorAll('.work-item').forEach(()=>{}); // ensure cards exist
            {
                const cards=document.querySelectorAll('.service-card');
                if(cards.length>1){
                    const peekH=140; // approximate heading area in pixels
                    const cardH=cards[0].offsetHeight;
                    const clipBody=`inset(0 0 ${cardH-peekH}px 0)`; // keep heading, hide body
                    const clipHeadOnly=i=>`inset(${cardH-peekH}px 0 0 0)`; // only heading visible
                    const scrollPerCard=cardH;
                    const totalScroll=scrollPerCard*(cards.length-1);
                    const stl=gsap.timeline({
                        scrollTrigger:{
                            trigger:'.services-stack',start:'top 75%',
                            end:()=>`+=${totalScroll}`,scrub:1.5,
                            invalidateOnRefresh:true
                        }
                    });
                    cards.forEach((card,i)=>{
                        const desc=card.querySelector('.service-desc');
                        const tags=card.querySelectorAll('.service-tag');
                        const body=[desc,...tags].filter(Boolean);
                        if(i===0){
                            stl.to(card,{clipPath:clipBody,duration:1},0);
                            stl.to(body,{opacity:0.05,duration:1},0);
                        }else{
                            stl.fromTo(card,{clipPath:clipHeadOnly(i)},{clipPath:'inset(0 0 0 0)',duration:0.65},i-1);
                            stl.fromTo(body,{opacity:0.05},{opacity:1,duration:0.55},i-1);
                            if(i<cards.length-1){
                                stl.to(card,{clipPath:clipBody,duration:1},i);
                                stl.to(body,{opacity:0.05,duration:1},i);
                            }
                        }
                    });
                }
            }

            // ── Section labels (Selected Work / Core Modules) line+fade ──
            document.querySelectorAll('.section-label').forEach(el=>{
                gsap.fromTo(el,{opacity:0,y:-14},{
                    opacity:1,y:0,duration:0.9,ease:easeSoft,
                    scrollTrigger:{trigger:el,start:'top 88%',toggleActions:'play none none reverse'}
                });
            });

            // ── CTA figure reveal (preserves CSS translateY(-50%) via GSAP yPercent) ──
            gsap.utils.toArray('.cta-figure').forEach(el=>{
                gsap.fromTo(el,{x:80,opacity:0,yPercent:-50},{
                    x:0,opacity:1,yPercent:-50,duration:1.6,ease:easeSoft,
                    scrollTrigger:{trigger:'.cta',start:'top 70%',toggleActions:'play none none reverse'}
                });
            });
        })();

        // ── GITHUB LIVE METRICS ──
        const GithubData = (() => {
            const CK = 'aegntic:gh-data', CM = 6*60*60*1000;
            const FB = { totalPublicRepos: 42, totalStars: 72, followers: 16 };
            function load() {
                try { const r = localStorage.getItem(CK); if (!r) return null;
                    const d = JSON.parse(r); if (Date.now()-d.fetchedAt < CM) return d;
                } catch(e){} return null;
            }
            function save(d) { try { localStorage.setItem(CK, JSON.stringify(d)); } catch(e){} }
            async function fetchGH() {
                try {
                    const [p, r] = await Promise.all([
                        window.fetch('https://api.github.com/users/aegntic'),
                        window.fetch('https://api.github.com/users/aegntic/repos?per_page=100&sort=stars&type=public')
                    ]);
                    const pj = await p.json(), rj = await r.json();
                    const d = {
                        totalPublicRepos: pj.public_repos||FB.totalPublicRepos,
                        totalStars: rj.reduce((s,x)=>s+x.stargazers_count,0)||FB.totalStars,
                        followers: pj.followers||FB.followers,
                        fetchedAt: Date.now()
                    };
                    save(d); return d;
                } catch(e) { return FB; }
            }
            return { load, fetch: fetchGH, FB };
        })();

        function countUp(el, t, d=1200) {
            const s = parseInt(el.textContent)||0; if(s===t)return;
            const st = performance.now();
            function k(n) {
                const p = Math.min((n-st)/d,1);
                el.textContent = Math.round(s+(t-s)*(1-Math.pow(1-p,3)));
                if(p<1) requestAnimationFrame(k);
            }
            requestAnimationFrame(k);
        }

        // ── GITHUB CARD FLIP ──
        function openGhCard(){
            document.getElementById('ghOverlay').classList.add('open');
            document.body.style.overflow='hidden';
            // Fetch fresh GH stats for the card
            GithubData.fetch().then(d=>{
                const sr=document.getElementById('gh-stat-repos');
                const ss=document.getElementById('gh-stat-stars');
                const sf=document.getElementById('gh-stat-followers');
                if(sr)sr.textContent=d.totalPublicRepos;
                if(ss)ss.textContent=d.totalStars;
                if(sf)sf.textContent=d.followers;
            });
        }
        function closeGhCard(e){
            if(e && e.target!==e.currentTarget) return;
            document.getElementById('ghOverlay').classList.remove('open');
            document.body.style.overflow='';
        }
        document.addEventListener('keydown',e=>{
            if(e.key==='Escape') closeGhCard();
        });

        // Fetch immediately (cache-first, background refresh)
        const ghPromise = (async () => {
            const cached = GithubData.load();
            if (cached) { GithubData.fetch(); return cached; }
            return await GithubData.fetch();
        })();

        // Animate when proof strip enters viewport
        const proofStrip = document.querySelector('.proof-strip');
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        let proofAnimated = false;

        function applyGH(d) {
            const sr = document.getElementById('stat-repos'),
                  ss = document.getElementById('stat-stars'),
                  sf = document.getElementById('stat-followers');
            if (reduceMotion) {
                if(sr) sr.textContent = d.totalPublicRepos;
                if(ss) ss.textContent = d.totalStars;
                if(sf) sf.textContent = d.followers;
            } else {
                if(sr) countUp(sr, d.totalPublicRepos);
                if(ss) countUp(ss, d.totalStars);
                if(sf) countUp(sf, d.followers);
            }
        }

        if (proofStrip) {
            if (reduceMotion) {
                ghPromise.then(applyGH);
            } else {
                const io = new IntersectionObserver(async (entries) => {
                    for (const e of entries) {
                        if (e.isIntersecting && !proofAnimated) {
                            proofAnimated = true;
                            const d = await ghPromise;
                            applyGH(d);
                            io.unobserve(e.target);
                        }
                    }
                }, { threshold: 0.3 });
                io.observe(proofStrip);
            }
        }
    </script>
</body>
</html>
