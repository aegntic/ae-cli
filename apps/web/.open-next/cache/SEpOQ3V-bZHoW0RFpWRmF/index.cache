bg-bg-card-hover\" style=\"animation-delay:750ms\"><div class=\"flex h-11 w-11 items-center justify-center rounded-xl text-sm font-bold text-white transition-transform duration-200 group-hover:scale-110\" style=\"background-color:#f97316\">B</div><div class=\"text-center\"><div class=\"text-sm font-medium text-text-primary\">BlockRun</div><div class=\"mt-0.5 text-xs text-text-muted\">on-chain data</div></div></div><div class=\"group relative flex flex-col items-center gap-3 rounded-xl border border-border-subtle bg-bg-card p-5 transition-all duration-200 hover:border-border hover:bg-bg-card-hover\" style=\"animation-delay:800ms\"><div class=\"flex h-11 w-11 items-center justify-center rounded-xl text-sm font-bold text-white transition-transform duration-200 group-hover:scale-110\" style=\"background-color:#14b8a6\">W</div><div class=\"text-center\"><div class=\"text-sm font-medium text-text-primary\">Wokelo</div><div class=\"mt-0.5 text-xs text-text-muted\">private markets</div></div></div><div class=\"group relative flex flex-col items-center gap-3 rounded-xl border border-border-subtle bg-bg-card p-5 transition-all duration-200 hover:border-border hover:bg-bg-card-hover\" style=\"animation-delay:850ms\"><div class=\"flex h-11 w-11 items-center justify-center rounded-xl text-sm font-bold text-white transition-transform duration-200 group-hover:scale-110\" style=\"background-color:#a855f7\">S</div><div class=\"text-center\"><div class=\"text-sm font-medium text-text-primary\">Saperly</div><div class=\"mt-0.5 text-xs text-text-muted\">agent phone</div></div></div></div><div class=\"mt-10 text-center\"><a class=\"inline-flex items-center gap-2 text-sm text-accent transition-colors hover:text-accent-dim\" href=\"/tools\">See all 1,300+ tools<span>→</span></a></div></div></section><section class=\"px-6 py-20 md:py-28\"><div class=\"mx-auto max-w-5xl\"><h2 class=\"text-center text-3xl font-bold tracking-tight md:text-4xl\"><span class=\"gradient-text\">Tell your agent what to do.</span><br/><span class=\"text-text-secondary text-xl font-normal md:text-2xl\">It picks the tools itself.</span></h2><div class=\"mt-16 grid gap-6 md:grid-cols-3\"><div class=\"relative\"><div class=\"rounded-xl border border-border bg-bg-card p-6 transition-colors hover:border-accent/30\"><div class=\"mb-4 flex items-center gap-3\"><span class=\"flex h-9 w-9 items-center justify-center rounded-lg bg-accent/10 font-mono text-xs font-semibold text-accent\">01</span><h3 class=\"text-lg font-semibold\">Discover</h3></div><div class=\"rounded-lg bg-bg p-4\"><code class=\"code-block text-text-secondary\">aegntic.discover({ q: &quot;twitter posts&quot; })</code></div><p class=\"mt-3 text-sm text-text-muted\">12 candidates, ranked by fit and price</p></div><div class=\"absolute top-1/2 -right-3 hidden h-px w-6 bg-border md:block\"></div></div><div class=\"relative\"><div class=\"rounded-xl border border-border bg-bg-card p-6 transition-colors hover:border-accent/30\"><div class=\"mb-4 flex items-center gap-3\"><span class=\"flex h-9 w-9 items-center justify-center rounded-lg bg-accent/10 font-mono text-xs font-semibold text-accent\">02</span><h3 class=\"text-lg font-semibold\">Inspect</h3></div><div class=\"rounded-lg bg-bg p-4\"><code class=\"code-block text-text-secondary\">aegntic.inspect(tool)</code></div><p class=\"mt-3 text-sm text-text-muted\">Full schema, pricing, and reliability score</p></div><div class=\"absolute top-1/2 -right-3 hidden h-px w-6 bg-border md:block\"></div></div><div class=\"relative\"><div class=\"rounded-xl border border-border bg-bg-card p-6 transition-colors hover:border-accent/30\"><div class=\"mb-4 flex items-center gap-3\"><span class=\"flex h-9 w-9 items-center justify-center rounded-lg bg-accent/10 font-mono text-xs font-semibold text-accent\">03</span><h3 class=\"text-lg font-semibold\">Run</h3></div><div class=\"rounded-lg bg-bg p-4\"><code class=\"code-block text-text-secondary\">aegntic.run(&quot;twitter.search&quot;, params)</code></div><p class=\"mt-3 text-sm text-text-muted\">Execute instantly. Pay per call. No sign-ups.</p></div></div></div></div></section><section class=\"px-6 py-20 md:py-28\"><div class=\"mx-auto max-w-5xl\"><div class=\"rounded-2xl border border-border bg-bg-elevated p-8 md:p-14\"><div class=\"grid items-center gap-12 md:grid-cols-2\"><div><h2 class=\"text-3xl font-bold tracking-tight md:text-4xl\">We killed the<br/><span class=\"gradient-accent bg-clip-text text-transparent\">subscriptions.</span></h2><p class=\"mt-4 text-base leading-relaxed text-text-secondary md:text-lg\">Your agent has <span class=\"text-text-primary font-medium\">one balance</span> to use all the tools. Pay only for the calls your agent makes.</p><div class=\"mt-8 grid grid-cols-3 gap-6\"><div><div class=\"text-2xl font-bold text-text-primary\">1,300+</div><div class=\"mt-1 text-sm text-text-muted\">Tools</div></div><div><div class=\"text-2xl font-bold text-text-primary\">13+</div><div class=\"mt-1 text-sm text-text-muted\">Providers</div></div><div><div class=\"text-2xl font-bold text-text-primary\">1</div><div class=\"mt-1 text-sm text-text-muted\">Balance</div></div></div></div><div class=\"rounded-xl border border-border bg-bg-card p-6\"><div class=\"mb-4 flex items-center gap-3 text-sm text-text-muted\"><div class=\"flex h-8 w-8 items-center justify-center rounded-lg bg-accent/10\"><svg viewBox=\"0 0 20 20\" class=\"h-4 w-4 fill-accent\"><path d=\"M10 2a8 8 0 100 16 8 8 0 000-16zm1 11H9v-2h2v2zm0-4H9V5h2v4z\"></path></svg></div><span class=\"font-mono text-xs\">~/agents/research-bot</span></div><div class=\"space-y-3\"><div class=\"flex items-center justify-between rounded-lg bg-bg p-3\"><span class=\"text-sm text-text-secondary\">Balance</span><span class=\"font-mono text-lg font-semibold text-text-primary\">$3.00</span></div><div class=\"space-y-2\"><div class=\"flex items-center justify-between rounded-lg border border-border-subtle bg-bg-elevated px-3 py-2 text-xs\"><span class=\"font-mono text-text-muted\">twitter/search</span><span class=\"text-text-muted\">$0.001</span></div><div class=\"flex items-center justify-between rounded-lg border border-border-subtle bg-bg-elevated px-3 py-2 text-xs\"><span class=\"font-mono text-text-muted\">reddit/frontpage</span><span class=\"text-text-muted\">$0.002</span></div><div class=\"flex items-center justify-between rounded-lg border border-border-subtle bg-bg-elevated px-3 py-2 text-xs\"><span class=\"font-mono text-text-muted\">pdl/person</span><span class=\"text-text-muted\">$0.010</span></div></div></div></div></div></div></div></section><section class=\"px-6 py-20 md:py-28\"><div class=\"mx-auto max-w-5xl\"><div class=\"text-center\"><h2 class=\"text-3xl font-bold tracking-tight md:text-4xl\">Three ways to connect.</h2><p class=\"mt-3 text-text-secondary\">Same registry, same balance, whichever your agent speaks.</p></div><div class=\"mt-12 grid gap-5 md:grid-cols-3\"><a class=\"group relative rounded-xl border border-border bg-bg-card p-6 transition-all duration-200 hover:border-accent/40 hover:bg-bg-card-hover\" href=\"https://docs.aegntic.ai/guide/quickstart-skill\"><div class=\"mb-1 text-xs font-medium uppercase tracking-wider text-accent\">For agents</div><h3 class=\"mt-1 text-xl font-semibold\">Skill</h3><p class=\"mt-2 text-sm text-text-muted\">One line into your agent’s chat.</p><div class=\"mt-5 rounded-lg bg-bg p-3\"><code class=\"code-block whitespace-pre text-xs text-text-secondary\">$ set up https://aegntic.ai/SKILL.md</code></div><div class=\"mt-4 flex items-center gap-1 text-sm text-accent opacity-0 transition-opacity group-hover:opacity-100\">Learn more <span>→</span></div></a><a class=\"group relative rounded-xl border border-border bg-bg-card p-6 transition-all duration-200 hover:border-accent/40 hover:bg-bg-card-hover\" href=\"https://docs.aegntic.ai/guide/quickstart-mcp\"><div class=\"mb-1 text-xs font-medium uppercase tracking-wider text-accent\">For Claude &amp; Cursor</div